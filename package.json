{
  "name": "localiza-saude-backend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/http/server.ts",
    "build": "bun build src/http/server.ts --outdir dist",
    "start": "NODE_ENV=production bun dist/server.ts",
    "test": "bun test",
    "generate": "bunx --bun prisma generate",
    "migrate": "bunx --bun prisma migrate dev",
    "studio": "bunx --bun prisma studio",
    "seed": "bunx --bun prisma db seed"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.5",
    "@better-auth/prisma-adapter": "^1.5.5",
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-auth": "^1.5.5",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "glob": "^13.0.6",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
