model user {
  id            String     @id @default(cuid())
  name          String
  firstName     String?    @map("first_name")
  lastName      String?    @map("last_name")
  phone         String?
  email         String     @unique
  emailVerified Boolean    @default(false) @map("email_verified")
  image         String?
  role          UserRole   @default(CUSTOMER)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  sessions      session[]
  accounts      account[]
  ownedClinics  clinic[]   @relation("ClinicOwner")
  clinics       clinic[]   @relation("ClinicEmployees")

  healthcareProvider healthcare_provider?
  customer           customer?
  conversationMessages conversation_message[]
  pushTokens push_token[]
  notificationPreferences notification_preference[]
  notificationDeliveries notification_delivery[]
  supportRequests support_request[]

  @@map("users")
}

enum UserRole {
  HEALTHCARE_PROVIDER
  CUSTOMER
}
