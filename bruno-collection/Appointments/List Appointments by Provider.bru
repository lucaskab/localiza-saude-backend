meta {
  name: List Appointments by Provider
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/appointments?healthcareProviderId={{healthcareProviderId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

docs {
  Returns all appointments for a specific healthcare provider.

  **Query Parameters:**
  - healthcareProviderId: Filter by healthcare provider ID

  **Authentication required**
}
