meta {
  name: Get Clinic by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/clinics/{{clinicId}}
  body: none
  auth: none
}

params:path {
  clinicId: {{clinicId}}
}

docs {
  Get details of a specific clinic by its ID.
  
  Use the clinicId from environment variables or replace with actual clinic ID.
  No authentication required.
}
